# Day 0 漏写:Day 4 加 drift + sqlite3_flutter_libs 需要 CocoaPods 但项目里
# 没有 ios/Podfile,导致 iOS build 一直失败。本文件是 Flutter 3.44 标准模板。
#
# WHY iOS 16:product-design-v4.html 明确最低 iOS 16+。
# WHY 不用 Podfile.lock 入 git:CocoaPods lockfile 跟 Flutter SDK 版本强耦合,
# 每次 Flutter 升级都变,不入 git 避免 stale lock 误导 CI。本地生成即可。

# iOS 部署目标
platform :ios, '16.0'

# CocoaPods analytics 同步发网络包,影响 flutter build 延迟,关掉
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    # 单一 pod 临时提升到 iOS 17(只 device_info_plus),不动其它 pod 和 app
    #
    # WHY:device_info_plus 13.2.0 在 FPPDeviceInfoPlusPlugin.m:35 直接调
    # `[NSProcessInfo isiOSAppOnVision]`,这是 iOS 17+ API,且没 @available 守卫,
    # 用 iOS 16 deployment target 编译报 "no visible @interface"。
    # 该 pod 是 integration_test 传递依赖,只在 E2E 测试用,app 用户路径不碰,
    # 所以可以安全把它的 deployment target 提到 17.0(局部)。
    # 其它 pod 仍保持 16.0(跟 Runner.xcodeproj 一致)。
    if target.name == 'device_info_plus'
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
      end
    else
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      end
    end
  end
end